<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Listino prodotti — Dettaglio impianti, optionals e costi">
    <title>Listino — Gestione Prodotti</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/listino.css">
</head>

<body>

    <!-- ═══════════════════════════════════════════
       HEADER
       ═══════════════════════════════════════════ -->
    <header class="page-header">
        <div class="header-content">
            <div class="header-left">
                <!-- Spazio vuoto per bilanciare il layout -->
            </div>
            <h1 class="header-title">LISTINO</h1>
            <div class="header-right">
                <!-- Pulsante cestino (clear/reset) -->
                <button class="icon-button" id="clear-button" title="Pulisci selezione" onclick="clearSelection()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                    </svg>
                </button>
                <!-- Pulsante logout -->
                <a href="/logout" class="icon-button" id="logout-button" title="Esci">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <main class="container">

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert-error">
                <p>
                    <%= error %>
                </p>
            </div>
            <% } %>

                <!-- ═══════════════════════════════════════════
           SEZIONE: SELEZIONE PRODOTTO (Dropdown a cascata)
           ═══════════════════════════════════════════ -->
                <section class="section" id="selezione-section">
                    <h2 class="section-title">Configurazione Prodotto</h2>
                    <div class="select-grid">
                        <div class="select-card">
                            <label class="select-label" for="select-normativa">Normativa</label>
                            <div class="select-wrapper">
                                <select id="select-normativa" class="select-input" onchange="onNormativaChange()">
                                    <option value="">Seleziona normativa...</option>
                                </select>
                                <svg class="select-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </div>
                        <div class="select-card">
                            <label class="select-label" for="select-tipologia">Tipologia</label>
                            <div class="select-wrapper">
                                <select id="select-tipologia" class="select-input" disabled
                                    onchange="onTipologiaChange()">
                                    <option value="">Seleziona tipologia...</option>
                                </select>
                                <svg class="select-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </div>
                        <div class="select-card">
                            <label class="select-label" for="select-modello">Modello</label>
                            <div class="select-wrapper">
                                <select id="select-modello" class="select-input" disabled onchange="onModelloChange()">
                                    <option value="">Seleziona modello...</option>
                                </select>
                                <svg class="select-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </div>
                        <div class="select-card">
                            <label class="select-label" for="select-produzione">Produttività</label>
                            <div class="select-wrapper">
                                <select id="select-produzione" class="select-input" disabled
                                    onchange="onProduzioneChange()">
                                    <option value="">Seleziona produttività...</option>
                                </select>
                                <svg class="select-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ═══════════════════════════════════════════
           SEZIONE: DETTAGLIO IMPIANTO (dinamico)
           ═══════════════════════════════════════════ -->
                <section class="section hidden" id="impianto-section">
                    <h2 class="section-title">Dettaglio Impianto</h2>
                    <div class="table-wrapper">
                        <table class="data-table" id="table-impianto">
                            <thead>
                                <tr id="impianto-header"></tr>
                            </thead>
                            <tbody>
                                <tr id="impianto-row"></tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- ═══════════════════════════════════════════
           SEZIONE: OPTIONALS (dinamico)
           ═══════════════════════════════════════════ -->
                <section class="section hidden" id="optionals-section">
                    <h2 class="section-title">Optionals</h2>
                    <div class="optionals-grid" id="optionals-grid">
                        <!-- Generati via JS -->
                    </div>
                </section>

                <!-- ═══════════════════════════════════════════
           SEZIONE: COSTI (dinamico)
           ═══════════════════════════════════════════ -->
                <section class="section hidden" id="costi-section">
                    <h2 class="section-title">Costi</h2>
                    <div class="costi-summary" id="costi-summary">
                        <!-- Generati via JS -->
                    </div>
                    <div class="table-wrapper" style="margin-top: 20px;">
                        <table class="data-table" id="table-ore">
                            <thead>
                                <tr>
                                    <th>Ore S.E.</th>
                                    <th>Ore S.S.P.</th>
                                    <th>Ore S.S.H.</th>
                                    <th>Ore C.Q.</th>
                                    <th>Ore C.I.E.</th>
                                    <th>Ore C.I.S.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="ore-row"></tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <!-- Placeholder quando nessun prodotto è selezionato -->
                <section class="section" id="empty-state-section">
                    <div class="empty-state">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#86868b" stroke-width="1"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="16" y1="13" x2="8" y2="13" />
                            <line x1="16" y1="17" x2="8" y2="17" />
                        </svg>
                        <p>Seleziona un prodotto per visualizzarne i dettagli.</p>
                        <span>Usa i menu sopra per scegliere normativa, tipologia, modello e produttività.</span>
                    </div>
                </section>

    </main>

    <!-- Footer minimo -->
    <footer class="page-footer">
        <p>Listino &copy; 2026 &mdash; Benvenuto, <strong>
                <%= username %>
            </strong></p>
    </footer>

    <!-- ═══════════════════════════════════════════
       SCRIPT — Logica dropdown a cascata e caricamento dati
       ═══════════════════════════════════════════ -->
    <script>
        /**
         * Riferimenti DOM
         */
        const selNormativa = document.getElementById('select-normativa');
        const selTipologia = document.getElementById('select-tipologia');
        const selModello = document.getElementById('select-modello');
        const selProduzione = document.getElementById('select-produzione');

        const impiantoSection = document.getElementById('impianto-section');
        const optionalsSection = document.getElementById('optionals-section');
        const costiSection = document.getElementById('costi-section');
        const emptyState = document.getElementById('empty-state-section');

        /**
         * Inizializzazione: carica le opzioni iniziali
         */
        async function init() {
            try {
                const res = await fetch('/listino/api/filtri');
                const data = await res.json();

                // Popola normative
                populateSelect(selNormativa, data.normative);
                // Popola tipologie (tutte, senza filtro iniziale)
                populateSelect(selTipologia, data.tipologie);
            } catch (err) {
                console.error('Errore init:', err);
            }
        }

        /**
         * Popola un select con opzioni
         */
        function populateSelect(select, options, placeholder) {
            const currentVal = select.value;
            select.innerHTML = '';

            const defaultOpt = document.createElement('option');
            defaultOpt.value = '';
            defaultOpt.textContent = placeholder || select.previousElementSibling?.textContent
                ? `Seleziona ${(select.previousElementSibling?.textContent || '').toLowerCase()}...`
                : 'Seleziona...';
            select.appendChild(defaultOpt);

            options.forEach(opt => {
                const o = document.createElement('option');
                o.value = opt;
                o.textContent = opt;
                select.appendChild(o);
            });

            // Mantieni la selezione se ancora valida
            if (options.includes(currentVal)) {
                select.value = currentVal;
            }
        }

        /**
         * Handler: cambio normativa
         */
        function onNormativaChange() {
            const normativa = selNormativa.value;

            if (normativa) {
                selTipologia.disabled = false;
                // Ricarica tipologie (le tipologie non dipendono dalla normativa,
                // ma abilitiamo il flusso)
                fetchFiltri();
            } else {
                resetFrom('tipologia');
            }

            // Se un prodotto era già completamente selezionato, ricarica con la nuova normativa
            if (allSelected()) {
                loadProduct();
            }
        }

        /**
         * Handler: cambio tipologia
         */
        async function onTipologiaChange() {
            const tipologia = selTipologia.value;

            if (tipologia) {
                // Carica modelli filtrati per tipologia
                try {
                    const res = await fetch(`/listino/api/filtri?tipologia=${encodeURIComponent(tipologia)}`);
                    const data = await res.json();
                    populateSelect(selModello, data.modelli, 'Seleziona modello...');
                    selModello.disabled = false;
                    // Reset solo i downstream (produzione)
                    selProduzione.innerHTML = '<option value="">Seleziona produttività...</option>';
                    selProduzione.value = '';
                    selProduzione.disabled = true;
                    hideProductDetails();
                } catch (err) {
                    console.error('Errore caricamento modelli:', err);
                }
            } else {
                resetFrom('modello');
            }
        }

        /**
         * Handler: cambio modello
         */
        async function onModelloChange() {
            const tipologia = selTipologia.value;
            const modello = selModello.value;

            if (modello) {
                // Carica produzioni filtrate per tipologia e modello
                try {
                    const res = await fetch(`/listino/api/filtri?tipologia=${encodeURIComponent(tipologia)}&modello=${encodeURIComponent(modello)}`);
                    const data = await res.json();
                    populateSelect(selProduzione, data.produzioni, 'Seleziona produttività...');
                    selProduzione.disabled = false;
                    hideProductDetails();
                } catch (err) {
                    console.error('Errore caricamento produzioni:', err);
                }
            } else {
                resetFrom('produzione');
            }
        }

        /**
         * Handler: cambio produzione — carica il prodotto completo
         */
        function onProduzioneChange() {
            if (allSelected()) {
                loadProduct();
            } else {
                hideProductDetails();
            }
        }

        /**
         * Controlla se tutti i dropdown sono selezionati
         */
        function allSelected() {
            return selNormativa.value && selTipologia.value && selModello.value && selProduzione.value;
        }

        /**
         * Resetta i dropdown da un certo livello in poi
         */
        function resetFrom(level) {
            const levels = ['tipologia', 'modello', 'produzione'];
            const idx = levels.indexOf(level);

            if (idx <= 0) {
                selTipologia.value = '';
                selTipologia.disabled = !selNormativa.value;
            }
            if (idx <= 1) {
                selModello.innerHTML = '<option value="">Seleziona modello...</option>';
                selModello.value = '';
                selModello.disabled = true;
            }
            if (idx <= 2) {
                selProduzione.innerHTML = '<option value="">Seleziona produttività...</option>';
                selProduzione.value = '';
                selProduzione.disabled = true;
            }

            hideProductDetails();
        }

        /**
         * Carica dati filtri iniziali
         */
        async function fetchFiltri() {
            try {
                const res = await fetch('/listino/api/filtri');
                const data = await res.json();
                populateSelect(selTipologia, data.tipologie, 'Seleziona tipologia...');
            } catch (err) {
                console.error('Errore filtri:', err);
            }
        }

        /**
         * Carica i dettagli del prodotto selezionato
         */
        async function loadProduct() {
            const normativa = selNormativa.value;
            const tipologia = selTipologia.value;
            const modello = selModello.value;
            const produzione = selProduzione.value;

            try {
                // Carica prodotto e optionals in parallelo
                const [prodRes, optRes] = await Promise.all([
                    fetch(`/listino/api/prodotto?normativa=${encodeURIComponent(normativa)}&tipologia=${encodeURIComponent(tipologia)}&modello=${encodeURIComponent(modello)}&produzione=${encodeURIComponent(produzione)}`),
                    fetch(`/listino/api/optionals?tipologia=${encodeURIComponent(tipologia)}&modello=${encodeURIComponent(modello)}&normativa=${encodeURIComponent(normativa)}`)
                ]);

                if (!prodRes.ok) {
                    hideProductDetails();
                    return;
                }

                const prodotto = await prodRes.json();
                const optionals = await optRes.json();

                renderProduct(prodotto);
                renderOptionals(optionals);

                // Mostra le sezioni
                emptyState.classList.add('hidden');
                impiantoSection.classList.remove('hidden');
                costiSection.classList.remove('hidden');

                if (optionals.length > 0) {
                    optionalsSection.classList.remove('hidden');
                } else {
                    optionalsSection.classList.add('hidden');
                }

            } catch (err) {
                console.error('Errore caricamento prodotto:', err);
            }
        }

        /**
         * Renderizza i dettagli dell'impianto
         */
        function renderProduct(prodotto) {
            // Tabella equipment
            const headerRow = document.getElementById('impianto-header');
            const dataRow = document.getElementById('impianto-row');
            headerRow.innerHTML = '';
            dataRow.innerHTML = '';

            // Aggiungi la produzione come prima colonna
            addTableCell(headerRow, 'Produzione', true);
            addTableCell(dataRow, prodotto.produzione);

            // Aggiungi equipment
            Object.entries(prodotto.equipment).forEach(([label, value]) => {
                addTableCell(headerRow, label, true);
                addTableCell(dataRow, value);
            });

            // Aggiungi dimensioni se presenti
            if (prodotto.dimensioni) {
                addTableCell(headerRow, 'Dimensioni', true);
                addTableCell(dataRow, prodotto.dimensioni);
            }

            // Tabella ore
            const oreRow = document.getElementById('ore-row');
            oreRow.innerHTML = '';
            const ore = prodotto.ore;
            addTableCell(oreRow, ore.studiElettromeccanico);
            addTableCell(oreRow, ore.studioSoftwarePLC);
            addTableCell(oreRow, ore.studioSoftwareHMI);
            addTableCell(oreRow, ore.costruzioneQuadro);
            addTableCell(oreRow, ore.collaudoElettromeccanico);
            addTableCell(oreRow, ore.collaudoSoftware);

            // Riepilogo costi
            const costiSummary = document.getElementById('costi-summary');
            const costi = prodotto.costi;
            costiSummary.innerHTML = `
                <div class="costi-grid">
                    <div class="costo-card">
                        <span class="costo-label">Costo Manodopera</span>
                        <span class="costo-value">&euro; ${formatMoney(costi.manodopera)}</span>
                    </div>
                    <div class="costo-card">
                        <span class="costo-label">Costo Materiali</span>
                        <span class="costo-value">&euro; ${formatMoney(costi.materiali)}</span>
                    </div>
                    <div class="costo-card costo-card-total">
                        <span class="costo-label">Costo Totale</span>
                        <span class="costo-value costo-total">&euro; ${formatMoney(costi.totale)}</span>
                    </div>
                </div>
            `;
        }

        /**
         * Renderizza gli optionals
         */
        function renderOptionals(optionals) {
            const grid = document.getElementById('optionals-grid');
            grid.innerHTML = '';

            optionals.forEach(opt => {
                const card = document.createElement('label');
                card.className = 'optional-card';
                card.id = `optional-${opt.id}`;
                card.innerHTML = `
                    <input type="checkbox" name="optional_${opt.id}" class="optional-checkbox"
                           data-costo-manodopera="${opt.costi.manodopera}"
                           data-costo-materiali="${opt.costi.materiali}"
                           data-costo-totale="${opt.costi.totale}"
                           onchange="recalculateTotals()">
                    <span class="checkmark"></span>
                    <div class="optional-text">
                        <span class="optional-title">${escapeHtml(opt.descrizione)}</span>
                        <span class="optional-detail">&euro; ${formatMoney(opt.costi.totale)}</span>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        /**
         * Ricalcola i totali con gli optionals selezionati
         */
        function recalculateTotals() {
            // Per ora, i costi sono quelli del prodotto base + optionals selezionati
            // Questa funzione è un placeholder per funzionalità futura
        }

        /**
         * Nasconde le sezioni di dettaglio
         */
        function hideProductDetails() {
            impiantoSection.classList.add('hidden');
            optionalsSection.classList.add('hidden');
            costiSection.classList.add('hidden');
            emptyState.classList.remove('hidden');
        }

        /**
         * Pulisce tutte le selezioni e torna allo stato iniziale
         */
        function clearSelection() {
            selNormativa.value = '';
            resetFrom('tipologia');
            hideProductDetails();

            // Deseleziona tutti gli optionals
            document.querySelectorAll('.optional-checkbox').forEach(cb => {
                cb.checked = false;
            });
        }

        /**
         * Utilità: aggiunge una cella alla riga di una tabella
         */
        function addTableCell(row, content, isHeader) {
            const cell = document.createElement(isHeader ? 'th' : 'td');
            cell.textContent = content;
            row.appendChild(cell);
        }

        /**
         * Utilità: formatta un numero come valuta italiana
         */
        function formatMoney(num) {
            return Number(num).toLocaleString('it-IT', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        /**
         * Utilità: escape HTML per prevenire XSS
         */
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ─── Avvio ───
        init();
    </script>

</body>

</html>