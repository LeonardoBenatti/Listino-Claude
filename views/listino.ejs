<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Listino prodotti — Dettaglio impianti, optionals e costi">
    <title>Listino — Gestione Prodotti</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/listino.css">
</head>

<body>

    <!-- ═══════════════════════════════════════════
       HEADER
       ═══════════════════════════════════════════ -->
    <header class="page-header">
        <div class="header-content">
            <div class="header-left">
                <!-- Spazio vuoto per bilanciare il layout -->
            </div>
            <h1 class="header-title">LISTINO</h1>
            <div class="header-right">
                <!-- Pulsante cestino (clear/reset) -->
                <button class="icon-button" id="clear-button" title="Pulisci selezione" onclick="clearSelection()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6" />
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                        <line x1="10" y1="11" x2="10" y2="17" />
                        <line x1="14" y1="11" x2="14" y2="17" />
                    </svg>
                </button>
                <!-- Pulsante logout -->
                <a href="/logout" class="icon-button" id="logout-button" title="Esci">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <main class="container">

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert-error">
                <p>
                    <%= error %>
                </p>
            </div>
            <% } %>

                <% if (dati && dati.length> 0) { %>
                    <% const item=dati[0]; %>

                        <!-- ═══════════════════════════════════════════
           SEZIONE: INFORMAZIONI GENERALI
           ═══════════════════════════════════════════ -->
                        <section class="section" id="info-section">
                            <h2 class="section-title">Informazioni Generali</h2>
                            <div class="info-grid">
                                <div class="info-card">
                                    <span class="info-label">Normativa</span>
                                    <span class="info-value" id="info-normativa">
                                        <%= item.Normativa %>
                                    </span>
                                </div>
                                <div class="info-card">
                                    <span class="info-label">Tipologia</span>
                                    <span class="info-value" id="info-tipologia">
                                        <%= item.Tipologia %>
                                    </span>
                                </div>
                                <div class="info-card">
                                    <span class="info-label">Modello</span>
                                    <span class="info-value" id="info-modello">
                                        <%= item.Modello %>
                                    </span>
                                </div>
                                <div class="info-card">
                                    <span class="info-label">Produttività</span>
                                    <span class="info-value" id="info-produttivita">
                                        <%= item.Produttivita %>
                                    </span>
                                </div>
                            </div>
                        </section>

                        <!-- ═══════════════════════════════════════════
           SEZIONE: OPTIONALS
           ═══════════════════════════════════════════ -->
                        <section class="section" id="optionals-section">
                            <h2 class="section-title">Optionals</h2>
                            <div class="optionals-grid">
                                <label class="optional-card" id="optional-380">
                                    <input type="checkbox" name="optional_380" class="optional-checkbox">
                                    <span class="checkmark"></span>
                                    <div class="optional-text">
                                        <span class="optional-title">Alimentazione Speciale</span>
                                        <span class="optional-detail">380/440V 60Hz</span>
                                    </div>
                                </label>
                                <label class="optional-card" id="optional-220">
                                    <input type="checkbox" name="optional_220" class="optional-checkbox">
                                    <span class="checkmark"></span>
                                    <div class="optional-text">
                                        <span class="optional-title">Alimentazione Speciale</span>
                                        <span class="optional-detail">220V 50/60Hz</span>
                                    </div>
                                </label>
                            </div>
                        </section>

                        <!-- ═══════════════════════════════════════════
           SEZIONE: DETTAGLIO IMPIANTO
           ═══════════════════════════════════════════ -->
                        <section class="section" id="impianto-section">
                            <h2 class="section-title">Dettaglio Impianto</h2>
                            <div class="table-wrapper">
                                <table class="data-table" id="table-impianto">
                                    <thead>
                                        <tr>
                                            <th>Produzione</th>
                                            <th>Dimensioni</th>
                                            <th>Pressa</th>
                                            <th>Gruppo di Taglio</th>
                                            <th>Trabatto</th>
                                            <th>Elevatore</th>
                                            <th>Essiccatoio</th>
                                            <th>Raffreddatore</th>
                                            <th>Tipologia</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% dati.forEach((row, index)=> { %>
                                            <tr id="impianto-row-<%= index %>">
                                                <td>
                                                    <%= row.Produzione %>
                                                </td>
                                                <td>
                                                    <%= row.Dimensioni %>
                                                </td>
                                                <td>
                                                    <%= row.Pressa %>
                                                </td>
                                                <td>
                                                    <%= row.GruppoTaglio %>
                                                </td>
                                                <td>
                                                    <%= row.Trabatto %>
                                                </td>
                                                <td>
                                                    <%= row.Elevatore %>
                                                </td>
                                                <td>
                                                    <%= row.Essiccatoio %>
                                                </td>
                                                <td>
                                                    <%= row.Raffreddatore %>
                                                </td>
                                                <td>
                                                    <%= row.TipologiaImpianto %>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <!-- ═══════════════════════════════════════════
           SEZIONE: COSTI
           ═══════════════════════════════════════════ -->
                        <section class="section" id="costi-section">
                            <h2 class="section-title">Costi</h2>
                            <div class="table-wrapper">
                                <table class="data-table" id="table-costi">
                                    <thead>
                                        <tr>
                                            <th>Ore S.E.</th>
                                            <th>Ore S.S.P.</th>
                                            <th>Ore S.S.H.</th>
                                            <th>Ore C.Q.</th>
                                            <th>Ore C.I.E.</th>
                                            <th>Ore C.I.S.</th>
                                            <th>Costo Materiali</th>
                                            <th>Costo Manodopera</th>
                                            <th class="highlight">Costo Totale</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% dati.forEach((row, index)=> { %>
                                            <tr id="costi-row-<%= index %>">
                                                <td>
                                                    <%= row.OreSE %>
                                                </td>
                                                <td>
                                                    <%= row.OreSSP %>
                                                </td>
                                                <td>
                                                    <%= row.OreSSH %>
                                                </td>
                                                <td>
                                                    <%= row.OreCQ %>
                                                </td>
                                                <td>
                                                    <%= row.OreCIE %>
                                                </td>
                                                <td>
                                                    <%= row.OreCIS %>
                                                </td>
                                                <td>&euro; <%= Number(row.CostoMateriali).toLocaleString('it-IT') %>
                                                </td>
                                                <td>&euro; <%= Number(row.CostoManodopera).toLocaleString('it-IT') %>
                                                </td>
                                                <td class="highlight"><strong>&euro; <%=
                                                            Number(row.CostoTotale).toLocaleString('it-IT') %></strong>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Pulsante ESPANDI -->
                            <div class="expand-wrapper">
                                <button class="btn-expand" id="expand-button" onclick="toggleExpand()">
                                    <span>ESPANDI</span>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9" />
                                    </svg>
                                </button>
                            </div>
                        </section>

                        <% } else { %>
                            <!-- Nessun dato disponibile -->
                            <section class="section">
                                <div class="empty-state">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#86868b"
                                        stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                        <polyline points="14 2 14 8 20 8" />
                                        <line x1="16" y1="13" x2="8" y2="13" />
                                        <line x1="16" y1="17" x2="8" y2="17" />
                                    </svg>
                                    <p>Nessun dato disponibile nel listino.</p>
                                    <span>Carica un file CSV nella cartella <code>data/</code> per iniziare.</span>
                                </div>
                            </section>
                            <% } %>

    </main>

    <!-- Footer minimo -->
    <footer class="page-footer">
        <p>Listino &copy; 2026 &mdash; Benvenuto, <strong>
                <%= username %>
            </strong></p>
    </footer>

    <!-- Script -->
    <script>
        /**
         * Pulisce la selezione degli optionals (deseleziona tutte le checkbox)
         */
        function clearSelection() {
            document.querySelectorAll('.optional-checkbox').forEach(cb => {
                cb.checked = false;
            });
        }

        /**
         * Alterna l'espansione della sezione costi (placeholder per funzionalità futura)
         */
        function toggleExpand() {
            const btn = document.getElementById('expand-button');
            const costiSection = document.getElementById('costi-section');

            costiSection.classList.toggle('expanded');

            if (costiSection.classList.contains('expanded')) {
                btn.querySelector('span').textContent = 'COMPRIMI';
                btn.querySelector('svg').style.transform = 'rotate(180deg)';
            } else {
                btn.querySelector('span').textContent = 'ESPANDI';
                btn.querySelector('svg').style.transform = 'rotate(0deg)';
            }
        }
    </script>

</body>

</html>